{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://toruseo.jp",
          "https://toruseo.github.io",
          "http://localhost:5173",
          "http://127.0.0.1:5173"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["Content-Length"],
      "maxAgeSeconds": 3600
    }
  ]
}
